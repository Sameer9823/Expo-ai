# Clerk (https://dashboard.clerk.com)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/chat
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/chat

# LLM provider (OpenAI or OpenRouter)
OPENAI_API_KEY=sk-xxxxxxxxxxxx

# Postgres (Neon serverless) — stores conversations/messages
DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# Qdrant vector store — stores embedded lesson chunks
QDRANT_URL=https://your-cluster.qdrant.io
QDRANT_API_KEY=

# Optional: comma-separated Clerk user ids allowed to trigger re-ingestion
# from the /admin dashboard. Leave unset to allow any signed-in user (fine
# for solo/dev use, but set this before deploying with real users).
ADMIN_USER_IDS=
